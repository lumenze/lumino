# Lumino — Environment Variables
# Copy to .env.local and fill in values

# ── Server ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://lumino:lumino@localhost:5432/lumino
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256

# ── AI Services ────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
LUMINO_AI_AI_PROVIDER=cloud
LUMINO_AI_OPENAI_API_KEY=
LUMINO_AI_ANTHROPIC_API_KEY=

# ── CORS ───────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3100,http://localhost:3200
