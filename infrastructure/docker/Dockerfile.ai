FROM python:3.11-slim

WORKDIR /app

COPY packages/ai-services/pyproject.toml .
RUN pip install --no-cache-dir . 2>/dev/null || pip install --no-cache-dir fastapi uvicorn pydantic pydantic-settings httpx redis

COPY packages/ai-services/src/ src/

EXPOSE 8000
CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000"]
