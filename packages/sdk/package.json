{
  "name": "@lumino/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Lumino SDK — Embeddable digital adoption layer",
  "main": "./dist/lumino.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/lumino.esm.js",
      "require": "./dist/lumino.cjs.js",
      "script": "./dist/lumino.js"
    }
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "dev": "rollup -c rollup.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "analyze": "rollup -c rollup.config.mjs --environment ANALYZE:true"
  },
  "dependencies": {
    "@lumino/shared": "workspace:*",
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.0",
    "@rollup/plugin-node-resolve": "^15.2.0",
    "@rollup/plugin-replace": "^5.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^11.1.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "rollup": "^4.18.0",
    "rollup-plugin-postcss": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "tslib": "^2.6.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
